{
  "name": "sentry",
  "version": "0.9.40",
  "description": "Sentry Idle",
  "scripts": {
    "dev": "vite",
    "dev:debug": "vite --debug",
    "live": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ci:local": "node scripts/ci/run-local-ci.mjs",
    "ci:local:fast": "node scripts/ci/run-local-ci.mjs --fast",
    "balance:dungeons": "npx vite-node scripts/balance/run-dungeon-balance.ts",
    "release:changelog:resolve": "node scripts/release/resolve-release-changelog.mjs --validate-current",
    "release:changelog:validate": "node scripts/release/resolve-release-changelog.mjs --validate-current",
    "tests": "node scripts/run-tests.js",
    "test:lanes:validate": "node scripts/quality/validate-test-lanes.mjs",
    "test:lanes:report": "node scripts/quality/report-test-lanes.mjs",
    "test:lane:app": "node scripts/quality/run-vitest-lane.mjs app-integration",
    "test:lane:backend-runtime": "node scripts/quality/run-vitest-lane.mjs backend-runtime",
    "test:lane:compat": "node scripts/quality/run-vitest-lane.mjs save-bootstrap-compat",
    "test:timeouts:validate": "node scripts/quality/check-timeout-governance.mjs",
    "test:full": "npm run lint && npm run typecheck && npm run typecheck:tests && npm run test:ci && npm run coverage:ci && npm run build && npm run test:e2e",
    "test:ci": "vitest --config vitest.ci.mjs run",
    "coverage": "vitest --coverage",
    "coverage:ci": "vitest --config vitest.ci.mjs --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "bundle:check": "node scripts/check-bundle-size.js",
    "test:flaky": "node scripts/flaky-check.js",
    "test:e2e": "node scripts/playwright/run-playwright.mjs test",
    "db:dump": "node scripts/db/dump.js",
    "db:dump:render": "node scripts/db/dump.js --target=render",
    "db:restore": "node scripts/db/restore.js",
    "db:restore:render": "node scripts/db/restore.js --target=render",
    "db:reset:dump": "node scripts/db/reset-from-dump.js",
    "db:reset:dump:render": "node scripts/db/reset-from-dump.js --target=render",
    "backend:dev": "node backend/server.js",
    "backend:start": "node backend/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexAgo83/Sentry.git"
  },
  "keywords": [
    "sentry",
    "idle"
  ],
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.4",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "prisma": "^5.19.1",
    "rollup-plugin-visualizer": "^5.12.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "author": "a.agostini.fr@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AlexAgo83/Sentry/issues"
  },
  "homepage": "https://github.com/AlexAgo83/Sentry#readme",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.2",
    "pako": "^2.1.0",
    "pixi.js": "^7.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sweetalert2": "^11.26.17"
  }
}
